
DATABASE_URL="postgresql://postgres:password@localhost:5432/agrimart?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/agrimart?schema=public"

# JWT
JWT_SECRET="super-secret-key-change-in-production"
JWT_ACCESS_SECRET=agrimart-access-secret-change-in-prod
JWT_REFRESH_SECRET=agrimart-refresh-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Rate limiting
THROTTLE_TTL=1000
THROTTLE_LIMIT=10

# Supabase (fill in from Supabase → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

PORT=3000
NODE_ENV=development
